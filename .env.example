# Copy this to .env and fill in your values. Never commit .env to git.

# NVIDIA NIM API Key - free at build.nvidia.com, no credit card needed
NVIDIA_API_KEY=nvapi-your_key_here

# LLM Model
NVIDIA_MODEL_NAME=nvidia/nemotron-3-ultra-550b-a55b

# NVIDIA NIM base URL - do not change this
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Embedding model (runs locally, no API cost ever)
EMBEDDING_MODEL_NAME=BAAI/bge-large-en-v1.5

# Vector store
CHROMA_DB_PATH=./chroma_db

# Retrieval
TOP_K_RESULTS=5
CHUNK_SIZE=700
CHUNK_OVERLAP=100

# Web scraping identity
USER_AGENT=legal-rag-bot/1.0
